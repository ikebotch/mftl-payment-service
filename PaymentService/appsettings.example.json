{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=mftl_payments;Username=YOUR_DB_USER;Password=YOUR_DB_PASSWORD"
  },
  "Moolre": {
    "Mode": "Real",
    "BaseUrl": "https://api.moolre.com",
    "ApiKey": "YOUR_MOOLRE_API_KEY",
    "ApiUser": "YOUR_MOOLRE_USER",
    "WebhookSecret": "YOUR_MOOLRE_WEBHOOK_SECRET"
  },
  "PaymentProviders": {
    "GoCardless": {
      "Enabled": true,
      "Environment": "Live",
      "AccessToken": "YOUR_GOCARDLESS_ACCESS_TOKEN",
      "WebhookSecret": "YOUR_GOCARDLESS_WEBHOOK_SECRET"
    }
  },
  "ClientCallbacks": {
    "Apps": {
      "mftl-collections": {
        "SharedSecret": "YOUR_SHARED_SECRET"
      }
    }
  }
}
